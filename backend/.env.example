# AGRIFATHER Backend Environment Variables (Example)

# Server
PORT=5000
NODE_ENV=production

# JWT Secret (generate a strong random string)
JWT_SECRET=YOUR-JWT-SECRET-HERE

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=YOUR-GROQ-API-KEY-HERE

# Razorpay Payment Gateway (get from https://razorpay.com)
RAZORPAY_KEY_ID=YOUR-RAZORPAY-KEY-ID-HERE
RAZORPAY_KEY_SECRET=YOUR-RAZORPAY-KEY-SECRET-HERE

# MongoDB Atlas Connection String (if used)
MONGODB_URI=YOUR-MONGODB-URI-HERE

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.onrender.com

# Plans Pricing (in paise - INR * 100)
PLAN_MONTHLY_PRICE=39900
PLAN_YEARLY_PRICE=419900

# Free tier limits
FREE_MESSAGES_PER_DAY=10
PRO_MESSAGES_PER_DAY=9999
